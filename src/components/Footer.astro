---
import { basics } from '@cv';

const { name, label1, label2, image, location, profiles, email } = basics;
const { city, region } = location;

const linkedInfo = profiles.find((p) => p.network === 'LinkedIn');
const LinkedUrl = linkedInfo?.url;

const githubInfo = profiles.find((p) => p.network === 'GitHub');
const gitHubUrl = githubInfo?.url;

const printInfo = [email, LinkedUrl, gitHubUrl];
---

<footer>
  <div class="name-date">
    <p>{new Date().getFullYear()} {basics.name}</p>
  </div>
  <div class="container">
    <h2>
      Open to new opportunities or side hustles, feel free to get in touch!
    </h2>
    <h3>ramirofiscella@gmail.com</h3>
  </div>
  {
    email && (
      <a
        class="mail"
        href={`mailto:${email}`}
        title={`Send email to ${name} at ${email}`}
        target="_blank"
        rel="noopener noreferer"
      >
        Contact
      </a>
    )
  }
</footer>

<style>
  footer {
    width: 90vw;
    max-width: 1024px;
    margin: 0 auto 4rem auto;
    padding: 2rem;
    border-radius: 16px;
    background-color: var(--color-primario);
    color: var(--color-fondo);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .name-date {
    margin-bottom: 1rem;
  }
  .name-date p {
    font-family: var(--font-secundaria);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
    margin: 0;
    color: var(--color-fondo);
  }
  .container {
    margin-bottom: 2rem;
  }
  .container h2 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-fondo);
    line-height: 1.2;
  }
  .container h3 {
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0;
    color: var(--color-fondo);
  }
  .mail {
    display: inline-block;
    background-color: var(--color-fondo);
    color: var(--color-primario);
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition:
      background 0.3s ease,
      transform 0.3s ease;
  }
  .mail:hover {
    background-color: rgba(255, 255, 255, 0.9);
    transform: translateY(-2px);
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .container h2 {
      font-size: 1.8rem;
    }
    .container h3 {
      font-size: 1.3rem;
    }
    .mail {
      padding: 0.75rem 1.2rem;
      font-size: 0.9rem;
    }
  }
</style>
